              "endTime": {
                "type": "number"
              },
              "userId": {
                "type": "integer"
              },
              "maxNum": {
                "type": "integer"
              },
              "events": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "bundleName": {
                      "type": "string"
                    },
                    "timeStamp": {
                      "type": "number"
                    },
                    "eventId": {
                      "type": "integer"
                    },
                    "uid": {
                      "type": "integer"
                    },
                    "abilityName": {
                      "type": "string"
                    }
                  }
                }
              },
              "count": {
                "type": "integer"
              }
            }
          },
          "errCode": {
            "type": "string"
          },
          "errMsg": {
            "type": "string"
          },
          "suggestion": {
            "type": "string"
          }
        },
        "required": ["status"]
      }
    },
